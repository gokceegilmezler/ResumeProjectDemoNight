@model ResumeProjectDemoNight.Entities.Message
@{
    ViewData["Title"] = "Mesaj Detayları";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="bg-gray-900 rounded-lg p-8 max-w-4xl mx-auto mt-10">
    <div class="flex justify-between items-center border-b border-gray-800 pb-4 mb-6">
        <h2 class="text-2xl font-bold text-white">Mesaj Detayı</h2>
        <a href="/Message/MessageList" class="text-blue-400 hover:underline text-sm">← Listeye Dön</a>
    </div>

    <div class="space-y-6 text-gray-300">
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-gray-500 text-xs uppercase">Gönderen</label>
                <p class="text-lg font-medium text-white">@Model.NameSurname</p>
            </div>
            <div>
                <label class="block text-gray-500 text-xs uppercase">Tarih</label>
                <p>@Model.SendDate.ToString("dd.MM.yyyy HH:mm")</p>
            </div>
        </div>

        <div>
            <label class="block text-gray-500 text-xs uppercase">E-posta</label>
            <p>@Model.Email</p>
        </div>

        <div>
            <label class="block text-gray-500 text-xs uppercase">Konu</label>
            <p class="text-white font-semibold">@Model.Subject</p>
        </div>

        <div class="bg-gray-800 p-6 rounded-lg border border-gray-700">
            <label class="block text-gray-500 text-xs uppercase mb-2">Mesaj İçeriği</label>
            <p class="whitespace-pre-line leading-relaxed">@Model.MessageDetail</p>
           
        </div>
    </div>
</div>