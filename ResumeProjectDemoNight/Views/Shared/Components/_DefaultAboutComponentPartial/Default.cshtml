
<section id="about">

	<div class="container">

		<!-- section title -->
		<h2 class="section-title wow fadeInUp">Hakkımda</h2>

		<div class="spacer" data-height="60"></div>

		<div class="row">

			<div class="col-md-3">
				<div class="text-center text-md-left">
					<!-- avatar image -->
					<img src="@ViewBag.About?.ImageUrl" alt="@ViewBag.About?.NameSurname" />
				</div>
				<div class="spacer d-md-none d-lg-none" data-height="30"></div>
			</div>

			<div class="col-md-9 triangle-left-md triangle-top-sm">
				<div class="rounded bg-white shadow-dark padding-30">
					<div class="row">
						<div class="col-md-6">
							<!-- about text -->
							<p>@ViewBag.About?.Description</p>
							<div class="mt-3">
								<a href="#" class="btn btn-default">Download CV</a>
							</div>
							<div class="spacer d-md-none d-lg-none" data-height="30"></div>
						</div>
						<div class="col-md-6">
							<!-- skill item -->
							@if (ViewBag.Skill != null)
							{
								@foreach (var skill in ViewBag.Skill)
								{
									<div class="skill-item">
										<div class="skill-info clearfix">
											<h4 class="float-left mb-3 mt-0">@skill.SkillName</h4>
											<span class="float-right">@skill.SkillDegree%</span>
										</div>
										<div class="progress">
											<div class="progress-bar data-background"
												 role="progressbar"
												 aria-valuemin="0"
												 aria-valuemax="100"
												 aria-valuenow="@skill.SkillDegree"
												 data-color="#FFD15C"
												 style="width: @skill.SkillDegree%">
											</div>
										</div>
										<div class="spacer" data-height="20"></div>
									</div>
								}
							}

						</div>
					</div>
				</div>
			</div>

		</div>
		<!-- row end -->

		<div class="spacer" data-height="70"></div>

		<div class="row">

			<div class="col-md-3 col-sm-6">
				<div class="fact-item">
					<span class="icon icon-fire"></span>
					<div class="details">
						<h3 class="mb-0 mt-0 number"><em class="count">@ViewBag.TotalProjects</em></h3>
						<p class="mb-0">Tamamlanan Projeler</p>
					</div>
				</div>
				<div class="spacer d-md-none d-lg-none" data-height="30"></div>
			</div>

			<div class="col-md-3 col-sm-6">
				<div class="fact-item">
					<span class="icon icon-badge"></span>
					<div class="details">
						<h3 class="mb-0 mt-0 number"><em class="count">@ViewBag.TotalExperiences</em></h3>
						<p class="mb-0">Deneyimler</p>
					</div>
				</div>
				<div class="spacer d-md-none d-lg-none" data-height="30"></div>
			</div>

			<div class="col-md-3 col-sm-6">
				<div class="fact-item">
					<span class="icon icon-people"></span>
					<div class="details">
						<h3 class="mb-0 mt-0 number"><em class="count">@ViewBag.TotalTestimonials</em></h3>
						<p class="mb-0">Mutlu Müşteriler</p>
					</div>
				</div>
				<div class="spacer d-md-none d-lg-none" data-height="30"></div>
			</div>

			<div class="col-md-3 col-sm-6">
				<div class="fact-item">
					<span class="icon icon-envelope"></span>
					<div class="details">
						<h3 class="mb-0 mt-0 number"><em class="count">@ViewBag.TotalMessages</em></h3>
						<p class="mb-0">Alınan Mesajlar</p>
					</div>
				</div>
			</div>
		</div>
		</div>

	</div>

</section>