@model List<ResumeProjectDemoNight.Entities.SocialMedia>
@{
    ViewData["Title"] = "SocialMediaList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Social Connectivity</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#2b8cee",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
    <style>
        .social-icon-hover:hover .tooltip {
            opacity: 1;
            transform: translateY(-8px);
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-white antialiased">
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
        <div class="layout-container flex h-full grow flex-col">
            <!-- Navigation Header -->
            <header class="flex items-center justify-between border-b border-solid border-white/10 px-6 py-4 lg:px-20">
                <div class="flex items-center gap-3">
                    <div class="flex items-center justify-center size-8 rounded-lg bg-primary/20 text-primary">
                        <span class="material-symbols-outlined text-xl">share</span>
                    </div>
                    <h2 class="text-lg font-bold tracking-tight">Connect</h2>
                </div>
                <nav class="hidden md:flex gap-6 text-sm font-medium text-white/60">
                    <a class="hover:text-primary transition-colors" href="#">Home</a>
                    <a class="hover:text-primary transition-colors" href="#">Portfolio</a>
                    <a class="hover:text-primary transition-colors" href="#">Contact</a>
                </nav>
            </header>
            <!-- Main Content Section -->
            <main class="flex flex-1 flex-col items-center justify-center px-4 py-20">
                <div class="max-w-[600px] w-full text-center space-y-8">
                    <div class="space-y-3">
                        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-white">Sosyal Ağ Bağlantılarım</h1>
                        <p class="text-lg text-white/50 max-w-md mx-auto">Dijital ayak izimi keşfedin ve en son projelerim ile profesyonel güncellemelerimden haberdar olun.</p>
                    </div>
                    <!-- Minimalist Social Links Grid -->
                    <div class="flex items-center justify-center gap-6 py-10">
                        @foreach (var item in Model)
                        {
                            <div class="relative group flex flex-col items-center">
                                <!-- Sosyal Medya İkonu -->
                                <a aria-label="@item.Platform"
                                   class="flex items-center justify-center size-14 rounded-xl bg-white/5 border border-white/10 text-white/70 hover:text-primary hover:border-primary/50 hover:bg-primary/10 transition-all duration-300"
                                   href="@item.Url"
                                   target="_blank">
                                    <i class="@item.Icon text-2xl"></i>
                                </a>

                                <!-- Platform Adı -->
                                <span class="absolute -top-10 scale-0 group-hover:scale-100 transition-all duration-200 px-3 py-1 bg-primary text-white text-xs font-bold rounded-lg shadow-lg shadow-primary/20">
                                    @item.Platform
                                </span>

                                <!-- Güncelleme Butonu -->
                                <a href="/SocialMedia/UpdateSocialMedia/@item.SocialMediaId"
                                   class="mt-2 px-3 py-1 bg-blue-500/20 text-blue-400 hover:bg-blue-500 hover:text-white rounded text-xs font-bold transition-all">
                                    Güncelle
                                </a>
                                <br />

                                <!-- Silme Butonu -->
                                <a href="/SocialMedia/DeleteSocialMedia/@item.SocialMediaId"
                                   onclick="return confirm('Silmek istediğinize emin misiniz?')"
                                   class="px-3 py-1 bg-red-500/20 text-red-400 hover:bg-red-500 hover:text-white rounded text-xs font-bold transition-all">
                                    Sil
                                </a>
                            </div>
                        }
                        @* <!-- Instagram Link -->
                        <div class="relative group flex flex-col items-center">
                            <a aria-label="Instagram" class="flex items-center justify-center size-14 rounded-xl bg-white/5 border border-white/10 text-white/70 hover:text-primary hover:border-primary/50 hover:bg-primary/10 transition-all duration-300" href="https://instagram.com" target="_blank"><svg class="w-7 h-7 fill-current" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path></svg></a>
                            <span class="absolute -top-10 scale-0 group-hover:scale-100 transition-all duration-200 px-3 py-1 bg-primary text-white text-xs font-bold rounded-lg shadow-lg shadow-primary/20">Instagram</span>
                        </div>
                        <!-- GitHub Link -->
                        <div class="relative group flex flex-col items-center">
                            <a aria-label="GitHub" class="flex items-center justify-center size-14 rounded-xl bg-white/5 border border-white/10 text-white/70 hover:text-primary hover:border-primary/50 hover:bg-primary/10 transition-all duration-300" href="https://github.com" target="_blank"><svg class="w-7 h-7 fill-current" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg></a>
                            <span class="absolute -top-10 scale-0 group-hover:scale-100 transition-all duration-200 px-3 py-1 bg-primary text-white text-xs font-bold rounded-lg shadow-lg shadow-primary/20">GitHub</span>
                        </div>
                        <!-- LinkedIn Link -->
                        <div class="relative group flex flex-col items-center">
                            <a aria-label="LinkedIn" class="flex items-center justify-center size-14 rounded-xl bg-white/5 border border-white/10 text-white/70 hover:text-primary hover:border-primary/50 hover:bg-primary/10 transition-all duration-300" href="https://linkedin.com" target="_blank"><svg class="w-7 h-7 fill-current" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg></a>
                            <span class="absolute -top-10 scale-0 group-hover:scale-100 transition-all duration-200 px-3 py-1 bg-primary text-white text-xs font-bold rounded-lg shadow-lg shadow-primary/20">LinkedIn</span>
                        </div>
                    </div> *@
                   
                    
                </div>
            </main>
            <!-- Bottom Info Section -->
            <footer class="px-6 py-10 lg:px-20 flex flex-col md:flex-row justify-between items-center gap-6 border-t border-white/5">
                <div class="flex items-center gap-2 text-white/40 text-sm">
                    <span class="material-symbols-outlined text-sm">copyright</span>
                    <span>2024 Social Links. All rights reserved.</span>
                </div>
                <div class="flex gap-8">
                    <div class="flex flex-col items-center md:items-start gap-1">
                        <span class="text-[10px] uppercase tracking-wider text-white/30 font-bold">Availability</span>
                        <div class="flex items-center gap-2">
                            <span class="size-2 rounded-full bg-green-500 animate-pulse"></span>
                            <span class="text-xs text-white/60">Open for projects</span>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>
</body>
</html>

